# ===========================
# Bot Configuration
# ===========================
# Required: Your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token

# Deployment mode: 'polling' (development) or 'webhook' (production)
BOT_MODE=polling

# ===========================
# Webhook Configuration
# (Only needed when BOT_MODE=webhook)
# ===========================
# Your server's public domain (without https://)
WEBHOOK_DOMAIN=example.com

# Port for the Express webhook server
WEBHOOK_PORT=3000

# Secret path for webhook URL (defaults to BOT_TOKEN for security)
# WEBHOOK_SECRET_PATH=custom_secret_path

# ===========================
# Rate Limiting
# ===========================
# Time window in milliseconds (default: 1000)
RATE_LIMIT_WINDOW=1000

# Max requests per user within the time window (default: 3)
RATE_LIMIT_MAX=3

# ===========================
# Idempotency
# ===========================
# TTL for idempotency cache in milliseconds (default: 60000)
IDEMPOTENCY_TTL=60000

# ===========================
# Application
# ===========================
# Environment: development, staging, production
NODE_ENV=development

# Log level: debug, info, warn, error, fatal
LOG_LEVEL=info

# Default locale: en, id
DEFAULT_LOCALE=en

# Bot owner/admin Telegram user ID
BOT_OWNER_ID=
