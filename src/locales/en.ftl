# General
welcome = 
    👋 Welcome, { $name }!
    
    I'm your production-ready Telegram bot template. Use /help to see available commands.
help =
    📚 *Available Commands*
    
    /start \- Start the bot and see welcome message
    /help \- Show this help message
    /settings \- Configure your preferences
    /language \- Change bot language
    
    _Built with grammY framework_ 🤖
unknown-command = ❓ Unknown command. Use /help to see available commands.

# Settings
settings-title = 
    ⚙️ *Settings*
    
    Choose an option below to configure:
settings-language = 🌐 Language
settings-notifications = 🔔 Notifications
settings-back = ◀️ Back
settings-updated = ✅ Settings updated successfully!
language-changed = 🌐 Language changed to English.

# Language command
language-specify = ❓ Please specify a locale. Available: { $locales }
language-invalid = ❌ Invalid locale. Available: { $locales }
language-already-set = ℹ️ Language is already set to English.
language-set = ✅ Language changed to English.

# Rate Limiting
rate-limited = ⏳ Too many requests. Please wait a moment and try again.

# Errors
error-general = ❌ Something went wrong. Please try again later.
error-maintenance = 🔧 Bot is under maintenance. Please try again later.
