# General
welcome = 
    👋 Selamat datang, { $name }!
    
    Saya adalah template bot Telegram yang siap produksi. Gunakan /help untuk melihat perintah yang tersedia.
help =
    📚 *Perintah yang Tersedia*
    
    /start \- Mulai bot dan lihat pesan selamat datang
    /help \- Tampilkan pesan bantuan ini
    /settings \- Konfigurasi preferensi Anda
    /language \- Ubah bahasa bot
    
    _Dibangun dengan framework grammY_ 🤖
unknown-command = ❓ Perintah tidak dikenal. Gunakan /help untuk melihat perintah yang tersedia.

# Settings
settings-title = 
    ⚙️ *Pengaturan*
    
    Pilih opsi di bawah untuk mengkonfigurasi:
settings-language = 🌐 Bahasa
settings-notifications = 🔔 Notifikasi
settings-back = ◀️ Kembali
settings-updated = ✅ Pengaturan berhasil diperbarui!
language-changed = 🌐 Bahasa diubah ke Bahasa Indonesia.

# Language command
language-specify = ❓ Silakan tentukan bahasa. Tersedia: { $locales }
language-invalid = ❌ Bahasa tidak valid. Tersedia: { $locales }
language-already-set = ℹ️ Bahasa sudah diatur ke Bahasa Indonesia.
language-set = ✅ Bahasa diubah ke Bahasa Indonesia.

# Rate Limiting
rate-limited = ⏳ Terlalu banyak permintaan. Silakan tunggu sebentar dan coba lagi.

# Errors
error-general = ❌ Terjadi kesalahan. Silakan coba lagi nanti.
error-maintenance = 🔧 Bot sedang dalam pemeliharaan. Silakan coba lagi nanti.
